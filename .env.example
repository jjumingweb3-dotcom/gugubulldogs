# =========================================================================
# 구구불독스 플레이북 - 환경 변수 설정 템플릿
# =========================================================================

# 1. 관리자 비밀번호 설정
# 관리자 로그인 페이지(/admin)에서 사용하는 보안 암호입니다. (미입력 시 기본값: 1234)
ADMIN_PASSWORD=1234

# 2. 영상 소스 수집 채널 설정
# 유튜브 채널 ID (RSS 피드 수집용)
YOUTUBE_CHANNEL_ID=UCDTAqwh48UIZgczSQYTtFHw
# SOOP(아프리카TV) 방송국 BJ ID (새싹부 / 유소년부 각각 설정 가능)
SOOP_NEW_BJ_ID=pik7688
SOOP_OLD_BJ_ID=ncoolpis1245

# 3. Supabase 데이터베이스 설정 (실제 호스팅/운영 시 필수)
# 로컬 개발 환경에서는 이 값을 입력하지 않으면 자동으로 로컬 JSON 파일(data/db.json)을 데이터베이스로 사용합니다.
# 실제 호스팅(Vercel 등)에 배포할 때는 아래 Supabase 설정을 입력해 주세요.
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# 또는 클라이언트 단독 연동 시 아래 변수를 사용합니다.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
